rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    function postOwner(postId) {
      return get(/databases/$(database)/documents/posts/$(postId)).data.postedBy;
    }

    function chatExists(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId));
    }

    function isParticipant(chatId) {
      return isSignedIn() &&
        chatExists(chatId) &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // =========================
    // PROFILES
    // =========================
    match /profiles/{userId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isSignedIn()
        && request.auth.uid == userId;
    }

    match /profiles/{userId}/saved/{postId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == userId;
    }

    match /profiles/{userId}/reviews/{reviewId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid == userId;

      allow update, delete: if isSignedIn()
        && resource.data.fromUid == request.auth.uid;
    }

    // =========================
    // POSTS
    // =========================
    match /posts/{postId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.postedBy == request.auth.uid;

      allow update: if isSignedIn()
        && (
          resource.data.postedBy == request.auth.uid ||
          isAdmin()
        );

      allow delete: if isSignedIn()
        && (
          resource.data.postedBy == request.auth.uid ||
          isAdmin()
        );
    }

    // =========================
    // APPLICATIONS
    // =========================
    match /posts/{postId}/applications/{appId} {
      allow create: if isSignedIn()
        && request.resource.data.applicantUid == request.auth.uid;

      allow read: if isSignedIn();

      allow update: if isSignedIn()
        && (
          resource.data.applicantUid == request.auth.uid ||
          postOwner(postId) == request.auth.uid
        );

      allow delete: if isSignedIn()
        && resource.data.applicantUid == request.auth.uid;
    }

    // =========================
    // HIRE REQUESTS
    // =========================
    match /posts/{postId}/hireRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.hirerUid == request.auth.uid;

      allow read: if isSignedIn();

      allow update: if isSignedIn()
        && (
          resource.data.hirerUid == request.auth.uid ||
          postOwner(postId) == request.auth.uid
        );

      allow delete: if isSignedIn()
        && resource.data.hirerUid == request.auth.uid;
    }

    // =========================
    // REPORTS
    // =========================
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reportedByUid == request.auth.uid;

      allow get: if isSignedIn()
        && (
          resource.data.reportedByUid == request.auth.uid ||
          isAdmin()
        );

      allow list: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // =========================
    // ADMIN LOGS
    // =========================
    match /admin_logs/{logId} {
      allow create: if isAdmin()
        && request.resource.data.adminUid == request.auth.uid;

      allow get, list: if isAdmin();

      allow update, delete: if false;
    }

    // =========================
    // NOTIFICATIONS
    // =========================
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId is string
        && request.resource.data.type is string
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.isRead is bool;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.type == resource.data.type
        && request.resource.data.title == resource.data.title
        && request.resource.data.message == resource.data.message
        && request.resource.data.relatedPostId == resource.data.relatedPostId
        && request.resource.data.relatedChatId == resource.data.relatedChatId
        && request.resource.data.relatedPeerId == resource.data.relatedPeerId
        && request.resource.data.relatedPeerName == resource.data.relatedPeerName
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    // =========================
    // CHATS
    // =========================
    match /chats/{chatId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn()
        && (
          request.auth.uid in resource.data.participants ||
          (
            request.resource.data.participants is list &&
            request.auth.uid in request.resource.data.participants
          )
        );

      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.participants;
    }

    // =========================
    // MESSAGES
    // =========================
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isParticipant(chatId);

      allow create: if isParticipant(chatId)
        && (
          request.resource.data.senderId == request.auth.uid ||
          request.resource.data.senderId == "system"
        );

      allow update: if isParticipant(chatId);

      allow delete: if isParticipant(chatId);
    }

    // =========================
    // FALLBACK
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
